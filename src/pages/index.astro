<!-- Dot-grid canvas — is:inline preserves execution order -->
<script is:inline>
  const canvas = document.getElementById('dotCanvas');
  const ctx    = canvas.getContext('2d');
  const COLS = 17, ROWS = 17, H_GAP = 35, V_GAP = 35, ORIGIN_X = 24, ORIGIN_Y = 24;
  for (let r = 0; r < ROWS; r++) {
    for (let c = 0; c < COLS; c++) {
      ctx.beginPath();
      ctx.arc(ORIGIN_X + c * H_GAP, ORIGIN_Y + r * V_GAP, 2, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(255,255,255,0.15)';
      ctx.fill();
    }
  }
</script>

<!-- Matter.js physics engine — is:inline keeps it before the IIFE below -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/matter-js/0.19.0/matter.min.js"></script>

<!-- Hero logo physics -->
<script is:inline define:vars={{ base }}>
/* ── Hero logo physics ── */
(function () {
  const { Engine, Runner, Events, Bodies, World, Body, Mouse, MouseConstraint } = Matter;

  const CW = 608, CH = 608, SZ = 76, R = 15;
  const B = base.endsWith('/') ? base.slice(0, -1) : base;

  const logoDefs = [
    { src: B+'/logos/Symbol.svg.svg',             cx:  50, av: -0.10, delay:    0 },
    { src: B+'/logos/make_symbol.svg.svg',        cx: 150, av:  0.12, delay:  150 },
    { src: B+'/logos/mondaycom_symbol.svg.svg',   cx: 260, av: -0.08, delay:  300 },
    { src: B+'/logos/zapier_logo.svg.svg',        cx: 370, av:  0.09, delay:  450 },
    { src: B+'/logos/airtable_symbol.svg.svg',    cx: 470, av: -0.11, delay:  600 },
    { src: B+'/logos/calude.svg',                 cx: 100, av:  0.10, delay:  750 },
    { src: B+'/logos/n8n.svg',                    cx: 200, av: -0.09, delay:  900 },
    { src: B+'/logos/notion.svg',                 cx: 310, av:  0.08, delay: 1050 },
    { src: B+'/logos/open.svg',                   cx: 420, av: -0.07, delay: 1200 },
    { src: B+'/logos/vercel.svg',                 cx: 530, av:  0.11, delay: 1350 },
    { src: B+'/logos/Google Gemini.svg.svg',      cx:  70, av: -0.08, delay: 1500 },
    { src: B+'/logos/Google Mail.svg.svg',        cx: 180, av:  0.09, delay: 1650 },
    { src: B+'/logos/git.svg',                    cx: 560, av: -0.10, delay: 1800 },
    { src: B+'/image.png',                        profile: true, cx: 460, av:  0.06, delay: 1950 },
    { src: B+'/T024D9G3RV4-U05ENL69F37-458b1cdf045b-512.jpg', profile: true, cx: 220, av: -0.07, delay: 2100 },
  ];

  const sphereDefs = [
    { r: 28, color: '#371F5E', cx: 310, delay:   80 },
    { r: 20, color: '#EF9FC6', cx: 100, delay:  240 },
    { r: 32, color: '#3C5835', cx: 560, delay:  400 },
    { r: 22, color: '#EA812F', cx: 200, delay:  560 },
    { r: 26, color: '#D7B737', cx: 430, delay:  720 },
    { r: 18, color: '#EF9FC6', cx:  55, delay:  880 },
    { r: 30, color: '#371F5E', cx: 350, delay: 1030 },
    { r: 24, color: '#2563EB', cx: 140, delay: 1180 },
    { r: 20, color: '#16A34A', cx: 490, delay: 1330 },
    { r: 28, color: '#DC2626', cx: 270, delay: 1480 },
    { r: 22, color: '#7C3AED', cx: 390, delay: 1630 },
  ];

  const dotCard = document.querySelector('.dot-card');
  dotCard.style.cursor = 'grab';
  dotCard.style.touchAction = 'none';
  dotCard.addEventListener('mousedown', () => { dotCard.style.cursor = 'grabbing'; });
  dotCard.addEventListener('mouseup',   () => { dotCard.style.cursor = 'grab'; });
  dotCard.addEventListener('dragstart', e => e.preventDefault());

  let engine, runner, physBodies, physEls, timers;

  function start() {
    engine = Engine.create({ enableSleeping: true });
    engine.gravity.y = 1.1;
    runner = Runner.create();
    Runner.run(runner, engine);
    physBodies = [];
    physEls    = [];
    timers     = [];

    const wo = { isStatic: true, friction: 0.5, restitution: 0.15 };
    World.add(engine.world, [
      Bodies.rectangle(CW / 2, CH + 30, CW + 100, 60, wo),
      Bodies.rectangle(-30,    CH / 2,  60, CH * 3,   wo),
      Bodies.rectangle(CW + 30, CH / 2, 60, CH * 3,   wo),
    ]);

    logoDefs.forEach(d => {
      timers.push(setTimeout(() => {
        const el = document.createElement('div');
        el.className = 'float-card' + (d.profile ? ' float-card--profile' : '');
        const img = document.createElement('img');
        img.src = d.src; img.alt = '';
        img.draggable = false;
        el.appendChild(img);
        dotCard.appendChild(el);

        const b = Bodies.rectangle(d.cx, -SZ / 2 - 10, SZ, SZ, {
          chamfer:     { radius: R },
          restitution: 0.30,
          friction:    0.45,
          frictionAir: 0.012,
          density:     0.002,
          angle:       (Math.random() - 0.5) * 0.4,
        });
        Body.setAngularVelocity(b, d.av + (Math.random() - 0.5) * 0.05);
        b._hw = SZ / 2; b._hh = SZ / 2;
        World.add(engine.world, b);
        physBodies.push(b);
        physEls.push(el);
      }, d.delay));
    });

    sphereDefs.forEach(d => {
      timers.push(setTimeout(() => {
        const el = document.createElement('div');
        el.style.cssText = `position:absolute;top:0;left:0;width:${d.r * 2}px;height:${d.r * 2}px;` +
                           `border-radius:50%;background:${d.color};will-change:transform;`;
        dotCard.appendChild(el);

        const b = Bodies.circle(d.cx, -d.r - 10, d.r, {
          restitution: 0.38, friction: 0.35, frictionAir: 0.01, density: 0.0015,
        });
        Body.setAngularVelocity(b, (Math.random() - 0.5) * 0.2);
        b._hw = d.r; b._hh = d.r;
        World.add(engine.world, b);
        physBodies.push(b);
        physEls.push(el);
      }, d.delay));
    });

    Events.on(engine, 'afterUpdate', () => {
      for (let i = 0; i < physBodies.length; i++) {
        const b  = physBodies[i];
        const el = physEls[i];
        el.style.transform =
          `translate(${b.position.x - b._hw}px,${b.position.y - b._hh}px) rotate(${b.angle}rad)`;
      }
    });

    const mouse = Mouse.create(dotCard);
    const mc = MouseConstraint.create(engine, {
      mouse, constraint: { stiffness: 0.06, damping: 0.1, render: { visible: false } }
    });
    World.add(engine.world, mc);

    Events.on(mc, 'enddrag', function (e) {
      const maxSpeed = 6;
      const v = e.body.velocity;
      const speed = Math.sqrt(v.x * v.x + v.y * v.y);
      if (speed > maxSpeed) {
        const scale = maxSpeed / speed;
        Body.setVelocity(e.body, { x: v.x * scale, y: v.y * scale });
      }
    });
  }

  start();
})();
</script>

<!-- Reveal-on-scroll -->
<script is:inline>
  const _revealObserver = new IntersectionObserver((entries) => {
    for (const e of entries) {
      if (e.isIntersecting) {
        e.target.classList.add('in');
        _revealObserver.unobserve(e.target);
      }
    }
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach(el => _revealObserver.observe(el));
</script>

</body>
